# ── Database (External Access) ──────────────────────────────
# 5433 on host, 5432 inside docker network
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/analyst_agent
POSTGRES_DB=analyst_agent
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# ── Redis (External Access) ──────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── JWT Security ─────────────────────────────────────────────
SECRET_KEY=your_secret_key_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── LLM Providers ────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here
LLM_MODEL=deepseek/deepseek-chat
GEMINI_API_KEY=your_gemini_api_key_here

# ── Auth Strategy ─────────────────────────────────────────────
AUTH_STRATEGY=auth0
AUTH0_DOMAIN=your_auth0_domain
AUTH0_AUDIENCE=your_auth0_audience
AUTH0_CLIENT_ID=your_auth0_client_id

# ── Security & Encryption ────────────────────────────────────
AES_KEY=your_aes_encryption_key_here

# ── Docker Internal Networking ───────────────────────────────
OLLAMA_BASE_URL=http://ollama:11434
QDRANT_URL=http://qdrant:6333

# ── Application Settings ─────────────────────────────────────
CORS_ORIGINS=["http://localhost:3001","http://localhost:8002"]
LOG_LEVEL=INFO
MAX_UPLOAD_SIZE_MB=500
ENV=production
