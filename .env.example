# .env.example

# --- Database ---
# Local development: postgresql+asyncpg://postgres:postgres@localhost:5432/analyst_agent
# Docker: postgresql+asyncpg://postgres:postgres@db:5432/analyst_agent
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/analyst_agent

# --- Redis ---
# Local development: redis://localhost:6379/0
# Docker: redis://redis:6379/0
REDIS_URL=redis://redis:6379/0

# --- Qdrant (Vector DB for RAG) ---
# Docker: http://qdrant:6333
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=your-qdrant-api-key-if-needed

# --- JWT Authentication ---
# Generate a secure random string (e.g., openssl rand -hex 32)
SECRET_KEY=your-64-character-secret-key-goes-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- LLM API Keys ---
# Get your key from https://console.groq.com/
GROCK_API_KEY=your-groq-api-key-here

# --- Security ---
# AES-256 encryption key (32 bytes, base64-encoded) for DB credentials
# Example: python -c "import base64, os; print(base64.b64encode(os.urandom(32)).decode())"
AES_KEY=your-base64-encoded-32-byte-key-here

# --- CORS ---
# JSON list of allowed origins
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# --- Logging ---
# Valid levels: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
