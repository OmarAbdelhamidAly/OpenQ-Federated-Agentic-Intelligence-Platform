# ── Celery Worker Dockerfile for Universal Strategic Nexus ────────
FROM python:3.11-slim AS builder

RUN echo 'Acquire::http::Pipeline-Depth "0";' > /etc/apt/apt.conf.d/99fixbadproxy && \
    echo 'Acquire::Retries "5";' >> /etc/apt/apt.conf.d/99fixbadproxy && \
    sed -i 's|http://deb.debian.org|https://deb.debian.org|g' /etc/apt/sources.list.d/*.sources 2>/dev/null || true && \
    sed -i 's|http://deb.debian.org|https://deb.debian.org|g' /etc/apt/sources.list 2>/dev/null || true

RUN apt-get update && apt-get install -y --no-install-recommends --fix-missing \
    build-essential \
    libffi-dev \
    libpq-dev \
    git \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /build
COPY requirements.txt .
RUN pip install --no-cache-dir --upgrade pip && \
    pip install --no-cache-dir --default-timeout=1000 --retries 10 --prefix=/install -r requirements.txt

# ── Runtime ───────────────────────────────────────────────────
FROM python:3.11-slim

RUN echo 'Acquire::http::Pipeline-Depth "0";' > /etc/apt/apt.conf.d/99fixbadproxy && \
    echo 'Acquire::Retries "5";' >> /etc/apt/apt.conf.d/99fixbadproxy && \
    sed -i 's|http://deb.debian.org|https://deb.debian.org|g' /etc/apt/sources.list.d/*.sources 2>/dev/null || true && \
    sed -i 's|http://deb.debian.org|https://deb.debian.org|g' /etc/apt/sources.list 2>/dev/null || true

RUN apt-get update && apt-get install -y --no-install-recommends --fix-missing \
    libpq5 \
    git \
    curl \
    && rm -rf /var/lib/apt/lists/*

RUN groupadd -r appuser && useradd -r -g appuser -d /app -s /sbin/nologin appuser

WORKDIR /app
ENV PYTHONPATH=/app

COPY --from=builder /install /usr/local
COPY . .

RUN mkdir -p /tmp/tenants && chown -R appuser:appuser /tmp/tenants
RUN chown -R appuser:appuser /app

USER appuser

CMD ["celery", "-A", "app.worker:celery_app", "worker", \
    "-Q", "pillar.nexus", \
    "--loglevel=info", \
    "--concurrency=2", \
    "--prefetch-multiplier=1"]
