# ── Universal Document Intelligence Worker Dockerfile ────────────────────────
# Supports all document types via Unstructured.io:
# PDF, DOCX, PPTX, XLSX, HTML, EPUB, EML, TXT, MD, PNG, JPG, etc.
FROM python:3.11-slim AS builder

# Force HTTPS mirrors to bypass ISP HTTP redirect issues
RUN echo 'Acquire::http::Pipeline-Depth "0";' > /etc/apt/apt.conf.d/99fixbadproxy && \
    echo 'Acquire::Retries "5";' >> /etc/apt/apt.conf.d/99fixbadproxy && \
    sed -i 's|http://deb.debian.org|https://deb.debian.org|g' /etc/apt/sources.list.d/*.sources 2>/dev/null || true && \
    sed -i 's|http://deb.debian.org|https://deb.debian.org|g' /etc/apt/sources.list 2>/dev/null || true

RUN apt-get update && apt-get install -y --no-install-recommends --fix-missing \
    build-essential \
    libpango-1.0-0 \
    libpangocairo-1.0-0 \
    libcairo2 \
    libgdk-pixbuf-2.0-0 \
    libffi-dev \
    libpq-dev \
    shared-mime-info \
    # Unstructured.io dependencies (builder stage)
    libmagic1 \
    libmagic-dev \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /build
COPY requirements.txt .
RUN pip install --no-cache-dir --prefix=/install -r requirements.txt

# ── Runtime ───────────────────────────────────────────────────
FROM python:3.11-slim

# Force HTTPS mirrors to bypass ISP HTTP redirect issues
RUN echo 'Acquire::http::Pipeline-Depth "0";' > /etc/apt/apt.conf.d/99fixbadproxy && \
    echo 'Acquire::Retries "5";' >> /etc/apt/apt.conf.d/99fixbadproxy && \
    sed -i 's|http://deb.debian.org|https://deb.debian.org|g' /etc/apt/sources.list.d/*.sources 2>/dev/null || true && \
    sed -i 's|http://deb.debian.org|https://deb.debian.org|g' /etc/apt/sources.list 2>/dev/null || true

RUN apt-get update && apt-get install -y --no-install-recommends --fix-missing \
    libpango-1.0-0 \
    libpangocairo-1.0-0 \
    libcairo2 \
    libgdk-pixbuf-2.0-0 \
    libpq5 \
    shared-mime-info \
    curl \
    # PDF rendering (pdf2image & Unstructured PDF strategy)
    poppler-utils \
    # OCR engine (Unstructured ocr_only + hybrid strategy)
    tesseract-ocr \
    tesseract-ocr-ara \
    tesseract-ocr-eng \
    # MIME type detection (python-magic)
    libmagic1 \
    # Font support for PPTX/DOCX rendering
    fonts-liberation \
    fonts-dejavu-core \
    && rm -rf /var/lib/apt/lists/*

# Create non-root user
RUN groupadd -r appuser && useradd -r -g appuser -d /app -s /sbin/nologin appuser

WORKDIR /app
ENV PYTHONPATH=/app

# Copy installed Python packages from builder
COPY --from=builder /install /usr/local

# Copy application code
COPY . .

# Create directories for tenant uploads and HF cache
RUN mkdir -p /tmp/tenants /app/hf_cache && \
    chown -R appuser:appuser /tmp/tenants /app/hf_cache

# Ensure all files are owned by appuser
RUN chown -R appuser:appuser /app

# Add healthcheck tools
RUN apt-get update && apt-get install -y --no-install-recommends curl && rm -rf /var/lib/apt/lists/*

USER appuser

# No port exposed — workers don't serve HTTP
# No health check — Celery has its own monitoring

CMD ["celery", "-A", "app.worker:celery_app", "worker", \
    "--loglevel=info", \
    "--concurrency=4", \
    "--queues=pillar.pdf,pillar.docx,pillar.pptx,pillar.document,knowledge", \
    "--prefetch-multiplier=1"]
